# =============================================================================
# Korp Stack — Environment Variables (secrets only)
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- OpenClaw Gateway --------------------------------------------------------
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=          # shared secret for WS auth (generate: openssl rand -hex 32)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_LOG_LEVEL=warn          # trace | debug | info | warn | error
OPENCLAW_FRESH_START=1           # 1 = wipe volatile state on restart
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=Europe/Paris
